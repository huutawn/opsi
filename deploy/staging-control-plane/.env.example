# Compose identity and public ports
COMPOSE_PROJECT_NAME=opsi-staging
OPSI_STAGING_BIND_ADDRESS=0.0.0.0
OPSI_STAGING_HTTP_PORT=80
OPSI_STAGING_HTTPS_PORT=443

# Immutable application images. Replace each placeholder with a release tag or digest; latest is forbidden.
OPSI_CLOUD_IMAGE=ghcr.io/opsi-dev/opsi-cloud@sha256:REPLACE_WITH_64_HEX_IMAGE_DIGEST
OPSI_BOOTSTRAP_WORKER_IMAGE=ghcr.io/opsi-dev/opsi-bootstrap-worker@sha256:REPLACE_WITH_64_HEX_IMAGE_DIGEST

# PostgreSQL identity. The password is supplied through secrets/postgres-password.
POSTGRES_DB=opsi
POSTGRES_USER=opsi

# Opsi Cloud production invariants
OPSI_CLOUD_TTL=24h
OPSI_CLOUD_PUBLIC_BASE_URL=https://example.invalid
OPSI_CLOUD_PRODUCTION=true
OPSI_CLOUD_REQUIRE_AGENT_SIGNATURES=true
OPSI_CLOUD_OTP_DEV_ECHO=false
OPSI_CLOUD_OTP_OUTBOX_PATH=
OPSI_CLOUD_ALERTS_WEBHOOK_URL=
OPSI_CLOUD_ALERTS_MIN_SEVERITY=medium
OPSI_CLOUD_ALERTS_OUTBOX_PATH=

# SMTP delivery is mandatory in production mode. Password is file-backed.
OPSI_CLOUD_SMTP_HOST=REPLACE_WITH_SMTP_HOST
OPSI_CLOUD_SMTP_PORT=587
OPSI_CLOUD_SMTP_USERNAME=REPLACE_WITH_SMTP_USERNAME
OPSI_CLOUD_SMTP_FROM=REPLACE_WITH_SMTP_FROM_ADDRESS

# GitHub App identity. Secret values and private key are file-backed.
OPSI_CLOUD_GITHUB_APP_CLIENT_ID=REPLACE_WITH_GITHUB_APP_CLIENT_ID
OPSI_CLOUD_GITHUB_APP_CALLBACK_URL=https://example.invalid/v1/auth/browser/callback
OPSI_CLOUD_GITHUB_APP_ID=REPLACE_WITH_POSITIVE_GITHUB_APP_ID
