  "agent_install_url": "https://REPLACE_WITH_AGENT_ARTIFACT_HOST/path",
  "agent_install_sha256": "REPLACE_WITH_64_HEX_AGENT_SHA256",
  "ssh_known_hosts_path": "/run/secrets/ssh_known_hosts",
  "production": true,
  "timeout": "10m"
}
