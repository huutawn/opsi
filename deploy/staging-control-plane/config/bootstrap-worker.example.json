  "allow_insecure_internal_cloud_url": true,
  "bootstrap_worker_token_file": "/run/secrets/bootstrap-worker-token",
  "worker_id": "opsi-staging-bootstrap-worker-1",
  "poll_interval": "3s",
  "k3s_version": "REPLACE_WITH_PINNED_K3S_VERSION",
