# Compose
COMPOSE_PROJECT_NAME=opsi-dev
OPSI_DEV_BIND_ADDRESS=127.0.0.1
OPSI_DEV_HTTP_PORT=8080
OPSI_VERSION=dev

# PostgreSQL
POSTGRES_DB=opsi
POSTGRES_USER=opsi
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_PASSWORD

# Opsi Cloud
OPSI_CLOUD_TTL=24h
OPSI_CLOUD_DATABASE_URL=postgres://opsi:REPLACE_WITH_RANDOM_PASSWORD@postgres:5432/opsi?sslmode=disable
OPSI_CLOUD_PUBLIC_BASE_URL=http://127.0.0.1:8080
OPSI_CLOUD_PRODUCTION=false
OPSI_CLOUD_ENABLE_DEBUG_UI=false
OPSI_CLOUD_REQUIRE_AGENT_SIGNATURES=false
OPSI_CLOUD_OTP_DEV_ECHO=false
OPSI_CLOUD_OTP_OUTBOX_PATH=/var/lib/opsi/otp-outbox.log
OPSI_CLOUD_ALERTS_WEBHOOK_URL=
OPSI_CLOUD_ALERTS_MIN_SEVERITY=medium
OPSI_CLOUD_ALERTS_OUTBOX_PATH=/var/lib/opsi/alert-outbox.log

# SMTP
OPSI_CLOUD_SMTP_HOST=smtp.example.invalid
OPSI_CLOUD_SMTP_PORT=587
OPSI_CLOUD_SMTP_USERNAME=REPLACE_WITH_SMTP_USERNAME
OPSI_CLOUD_SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
OPSI_CLOUD_SMTP_FROM=opsi@example.invalid

# OAuth2
OPSI_CLOUD_AUTH_PROVIDER=generic
OPSI_CLOUD_AUTH_CLIENT_ID=REPLACE_WITH_OAUTH_CLIENT_ID
OPSI_CLOUD_AUTH_CLIENT_SECRET=REPLACE_WITH_OAUTH_CLIENT_SECRET
OPSI_CLOUD_AUTH_AUTH_URL=https://auth.example.invalid/authorize
OPSI_CLOUD_AUTH_TOKEN_URL=https://auth.example.invalid/token
OPSI_CLOUD_AUTH_USERINFO_URL=https://auth.example.invalid/userinfo
OPSI_CLOUD_AUTH_REDIRECT_URL=http://127.0.0.1:8080/v1/auth/browser/callback
OPSI_CLOUD_AUTH_SCOPES=openid,profile,email

# Internal secrets
OPSI_CLOUD_ALERTS_INTERNAL_TOKEN=REPLACE_WITH_RANDOM_ALERT_INTERNAL_TOKEN
OPSI_CLOUD_BOOTSTRAP_WORKER_TOKEN=REPLACE_WITH_RANDOM_BOOTSTRAP_WORKER_TOKEN
OPSI_CLOUD_BOOTSTRAP_SECRET_KEY=REPLACE_WITH_RANDOM_32_BYTE_BOOTSTRAP_SECRET_KEY
OPSI_CLOUD_AGENT_TOKENS=REPLACE_WITH_AGENT_TOKEN
